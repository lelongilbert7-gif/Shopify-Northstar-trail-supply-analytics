CREATE OR REPLACE TABLE `northstar-analysis-project.shopify_clean.master_sales` AS

SELECT
  -- Order level
  o.order_id,
  o.created_at AS order_date,
  o.customer_id,
  o.total_price AS order_total,

  -- Customer
  c.email,
  c.full_name,
  c.country,
  c.city,

  -- Line item (FACT)
  li.line_item_id,
  li.product_id,
  li.variant_id,
  li.sku,
  li.product_title,
  li.quantity,
  li.unit_price,
  li.net_line_revenue,

  -- Product
  p.vendor,
  p.product_type,
  p.variant_price,
  p.cost,
  p.gross_margin_value,

  -- Refunds
  r.refund_id,
  r.refund_amount,

  -- Derived metrics
  li.net_line_revenue - COALESCE(r.refund_amount, 0) AS net_revenue_after_refund

FROM `northstar-analysis-project.shopify_clean.order_line_items_clean` li

LEFT JOIN `northstar-analysis-project.shopify_clean.orders_clean` o
  ON li.order_id = o.order_id

LEFT JOIN `northstar-analysis-project.shopify_clean.customers_clean` c
  ON o.customer_id = c.customer_id

LEFT JOIN `northstar-analysis-project.shopify_clean.products_clean` p
  ON li.product_id = p.product_id

LEFT JOIN `northstar-analysis-project.shopify_clean.refunds_clean` r
  ON o.order_id = r.order_id;
